<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vivatlas">

        <!-- The app frame: a full-screen WebView onto the VIVATLAS server, behind a
             cold-start splash (Theme.Vivatlas.Splash hands off to Theme.Vivatlas). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Vivatlas.Splash"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout|uiMode|density|navigation">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Native sign-in (email/password + 2FA). Launched by MainActivity when
             there is no session; on success the WebView is already authenticated. -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout|uiMode|density|navigation" />

        <!-- Native password reset (email -> reset link), matching the login. -->
        <activity
            android:name=".ResetPasswordActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout|uiMode|density|navigation" />

        <!-- In-app browser for external links (catalogue -> GitHub, etc.), so the
             app never hands off to the system browser. -->
        <activity
            android:name=".WebActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout|uiMode|density|navigation" />

        <!-- The share target: appears in the Android share sheet for links/text.
             It has no UI of its own — it captures, toasts, and finishes. -->
        <activity
            android:name=".ShareActivity"
            android:exported="true"
            android:theme="@style/Theme.Vivatlas.Transparent"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>
    </application>
</manifest>
