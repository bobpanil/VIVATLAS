<?xml version="1.0" encoding="utf-8"?>
<!-- Native sign-in: the app's own login, not the web page. On success the token
     is written into the WebView cookie jar and MainActivity loads the catalogue
     already authenticated. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_bg"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">

        <ImageView
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:adjustViewBounds="true"
            android:src="@drawable/login_logo"
            android:contentDescription="@string/app_name" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="24dp">

            <TextView
                android:id="@+id/login_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_title"
                android:textColor="@color/login_ink"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Email + password. -->
            <LinearLayout
                android:id="@+id/primary_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/login_email"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:letterSpacing="0.04" />

                <EditText
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/field_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress"
                    android:textColor="@color/login_ink"
                    android:hint="@string/login_email_hint"
                    android:importantForAutofill="yes" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/login_password"
                    android:textAllCaps="true"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:letterSpacing="0.04" />

                <EditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/field_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:inputType="textPassword"
                    android:autofillHints="password"
                    android:textColor="@color/login_ink"
                    android:hint="@string/login_password_hint"
                    android:importantForAutofill="yes" />
            </LinearLayout>

            <!-- Second step: the 2FA code (hidden until the server asks for it). -->
            <LinearLayout
                android:id="@+id/mfa_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/mfa_prompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/login_mfa_prompt"
                    android:textColor="@color/login_ink"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/code"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/field_bg"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:inputType="number"
                    android:textColor="@color/login_ink"
                    android:letterSpacing="0.3"
                    android:hint="@string/login_code_hint" />

                <CheckBox
                    android:id="@+id/use_backup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/login_use_backup"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/error_red"
                android:textSize="14sp"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <Button
                    android:id="@+id/submit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_primary"
                    android:text="@string/login_submit"
                    android:textColor="@color/on_gold"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null" />

                <ProgressBar
                    android:id="@+id/progress"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/on_gold"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/forgot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/login_forgot"
                android:textColor="@color/link_gold"
                android:textSize="14sp"
                android:padding="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/change_server"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/change_server"
            android:textColor="@color/on_dark_muted"
            android:textSize="13sp"
            android:padding="6dp" />
    </LinearLayout>
</ScrollView>
