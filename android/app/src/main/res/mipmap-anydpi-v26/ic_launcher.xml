<?xml version="1.0" encoding="utf-8"?>
<!-- The dark1 icon is a finished navy squircle; as an adaptive icon the launcher
     masks it to its own shape (circle/squircle), clipping the black corners so it
     reads as a clean navy icon instead of a black square. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_fg" />
</adaptive-icon>
