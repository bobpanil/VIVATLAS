<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Brand palette, lifted from the web UI (app.css). -->
    <color name="brand_gold">#F7A501</color>
    <color name="brand_gold_dark">#D98C00</color>
    <color name="brand_dark">#04060D</color>
    <color name="brand_ink">#23251D</color>
    <color name="brand_canvas">#EEEFE9</color>
    <!-- Matches android.svg's navy so no seam shows if the mask exceeds it. -->
    <color name="ic_launcher_background">#0F141F</color>

    <!-- Native sign-in surfaces — a warm palette drawn from the logo (ivory
         figure, gold, espresso-black) so the screen and the logo read as one. -->
    <color name="login_bg">#100D0A</color>
    <color name="card">#F7F0E5</color>
    <color name="field">#FFFFFF</color>
    <color name="field_border">#E4DBC9</color>
    <color name="login_ink">#2A241F</color>
    <color name="text_muted">#6E6459</color>
    <color name="on_dark_muted">#9A9084</color>
    <color name="link_gold">#A86A00</color>
    <color name="on_gold">#1A1204</color>
    <color name="error_red">#C0392B</color>
    <!-- Splash/loading canvas — the app's dark navy, so the launch and the
         WebView's own dark surface meet without a flash. -->
    <color name="splash_bg">#04060D</color>
</resources>
